# Aanbevolen .gitignore file voor ems30 (BroJZ, mei 2021)
# Je kunt deze lijst indien nodig verder uitbreiden
# Learn more about .gitignore:
#     https://www.atlassian.com/git/tutorials/saving-changes/gitignore

# CCS generated files
**/.metadata
**/.jxbrowser-data
**/RemoteSystemsTempFiles
**/driverlib
**/tirtos_builds_CC3220S_LAUNCHXL_release_ccs
**/tirtos_builds_CC3220S_LAUNCHXL_debug_ccs
**/tirtos_builds_cc32xx_release_ccs
**/tirtos_builds_cc32xx_debug_ccs
**/.settings
**/.launches
**/.jxbrowser.userdata
**/Debug
**/Release
**/targetConfigs

# Generated by gcc
# Prerequisites
**/*.d
# Object files
**/*.o
**/*.obj
**/*.elf
# Linker output
**/*.map
# Precompiled Headers
**/*.gch
**/*.pch
# Libraries
**/*.lib
**/*.a
# Shared objects (inc. Windows DLLs)
**/*.dll
**/*.so
**/*.so.*
# Executables
**/*.exe
**/*.out
# Coverage testing tool files
**/*.gcno
**/*.gcda
**/*.gcov

# Temp files
**/~*
**/*.tmp

# Generated by MacOS
**/.DS_Store

# Generated by Windows
**/Thumbs.db
